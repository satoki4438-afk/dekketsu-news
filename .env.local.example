# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK（新規プロジェクト用）
FIREBASE_PROJECT_ID=dekketsu-news
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@dekketsu-news.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Vercel Cron Job 不正アクセス防止
# openssl rand -base64 32 などで生成
CRON_SECRET=your-random-secret-here

# X（Twitter）自動投稿
# https://developer.twitter.com/ でアプリ作成・OAuth 1.0a 認証情報を取得
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# デプロイURL（X投稿リンク用）
NEXT_PUBLIC_BASE_URL=https://dekketsu-news.vercel.app
